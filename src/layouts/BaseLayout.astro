---
import '../styles/global.css';
import SchemaOrg from '../components/SchemaOrg.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { site } from '../data/site';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noIndex?: boolean;
  includeSchema?: boolean;
}

const {
  title = 'IPTV Trial, 30-Day UK IPTV Subscription for £14.99',
  description = 'Start your IPTV trial for £14.99 — a full 30-day UK IPTV subscription with 50,000+ channels, sports, movies & series in 4K. Instant activation.',
  canonical = Astro.url.href,
  ogImage: rawOgImage = '/img/Men_watching_football_match_202607200445.webp',
  noIndex = false,
  includeSchema = true,
} = Astro.props;

const ogImage = rawOgImage.startsWith('http') ? rawOgImage : `${site.url}${rawOgImage}`;
---
<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <meta name="google-site-verification" content="9WzUj_v8e8AKCEGlEzRIw1ET19zUygD9X4u8K353T4E" />
    <meta name="theme-color" content="#0A1128" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <!-- Preload LCP hero image so the browser fetches it before parsing body -->
    <link
      rel="preload"
      as="image"
      href="/img/Men_watching_football_match_202607200445.webp"
      type="image/webp"
      fetchpriority="high"
    />

    {includeSchema && <SchemaOrg />}
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:rounded focus:bg-signal focus:px-3 focus:py-2 focus:text-base">Skip to content</a>
    <slot />

    <WhatsAppFloat />

    <script is:inline>
      (() => {
        if (typeof window === 'undefined') return;
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduced) return;

        // Auto-tag top-level sections inside <main> so every section animates in.
        const main = document.getElementById('main');
        if (main) {
          Array.from(main.children).forEach((el) => {
            if (!el.hasAttribute('data-reveal')) el.setAttribute('data-reveal', 'up');
          });
        }

        const targets = document.querySelectorAll('[data-reveal], [data-reveal-group]');
        if (!targets.length) return;

        if (!('IntersectionObserver' in window)) {
          targets.forEach((el) => el.classList.add('is-visible'));
          return;
        }

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );

        targets.forEach((el) => io.observe(el));
      })();
    </script>

    <script is:inline>
      // Shared auto-scroll driver for scrubbable carousels.
      // Deferred to window load so RAF loops don't compete during initial paint.
      window.addEventListener('load', () => {
        if (typeof window === 'undefined') return;
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduced) return;

        const containers = document.querySelectorAll('[data-auto-scroll]');
        if (!containers.length) return;

        containers.forEach((el) => {
          const speed = parseFloat(el.getAttribute('data-speed') || '0.5');
          const direction = el.getAttribute('data-direction') === 'reverse' ? -1 : 1;
          let paused = false;
          let resumeTimer = 0;
          let visible = false;
          let rafId = 0;

          const halfWidth = () => el.scrollWidth / 2;

          let pos = direction === -1 ? halfWidth() : 0;
          el.scrollLeft = pos;

          const tick = () => {
            if (!paused) {
              const half = halfWidth();
              if (half > 0) {
                pos += speed * direction;
                if (pos >= half) pos -= half;
                else if (pos < 0) pos += half;
                el.scrollLeft = pos;
              }
            }
            rafId = requestAnimationFrame(tick);
          };

          const startRAF = () => { if (!rafId) rafId = requestAnimationFrame(tick); };
          const stopRAF = () => { if (rafId) { cancelAnimationFrame(rafId); rafId = 0; } };

          const pause = () => {
            paused = true;
            if (resumeTimer) window.clearTimeout(resumeTimer);
          };
          const scheduleResume = () => {
            if (resumeTimer) window.clearTimeout(resumeTimer);
            resumeTimer = window.setTimeout(() => {
              const half = halfWidth();
              if (half > 0) {
                pos = el.scrollLeft % half;
                if (pos < 0) pos += half;
              } else {
                pos = el.scrollLeft;
              }
              paused = false;
            }, 1500);
          };

          el.addEventListener('pointerdown', pause);
          el.addEventListener('pointerup', scheduleResume);
          el.addEventListener('pointercancel', scheduleResume);
          el.addEventListener('pointerleave', scheduleResume);
          el.addEventListener('touchstart', pause, { passive: true });
          el.addEventListener('touchend', scheduleResume, { passive: true });
          el.addEventListener('wheel', () => { pause(); scheduleResume(); }, { passive: true });
          el.addEventListener('mouseenter', pause);
          el.addEventListener('mouseleave', scheduleResume);

          if ('IntersectionObserver' in window) {
            const io = new IntersectionObserver((entries) => {
              entries.forEach((entry) => {
                visible = entry.isIntersecting;
                if (visible) startRAF(); else stopRAF();
              });
            }, { threshold: 0 });
            io.observe(el);
          } else {
            startRAF();
          }
        });
      }, { once: true });
    </script>

    <!-- Google Analytics — deferred to avoid blocking FCP/LCP -->
    <script is:inline>
      window.addEventListener('load', () => {
        const s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-1VFPDLRZRJ';
        s.async = true;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', 'G-1VFPDLRZRJ');
      }, { once: true });
    </script>
  </body>
</html>
