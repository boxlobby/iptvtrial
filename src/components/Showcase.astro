---
import Placeholder from './Placeholder.astro';
import Icon from './Icon.astro';
import { showcase } from '../data/showcase';
---
<section class="section bg-subtle/40">
  <div class="container-x">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">See what’s inside</span>
      <h2 class="mt-4 text-3xl sm:text-4xl md:text-5xl font-bold">A cleaner way to watch UK TV</h2>
      <p class="mt-4 text-text-muted text-sm sm:text-base">Swipe through the interface. Same app on every device — Firestick to iPhone.</p>
    </div>

    <div class="mt-10 md:mt-14">
      <ul class="slider" role="list">
        {showcase.map((s) => (
          <li class="card overflow-hidden w-[85%] sm:w-[60%] md:w-[42%] lg:w-[32%]">
            <Placeholder
              label={`${s.label} — R2`}
              alt={s.title}
              src={s.r2 || undefined}
              aspect="aspect-[4/3]"
              width={800}
              height={600}
            />
            <div class="p-5">
              <span class="text-[11px] font-semibold uppercase tracking-widest text-brand-light">{s.label}</span>
              <h3 class="mt-2 text-lg font-semibold">{s.title}</h3>
              <p class="mt-1.5 text-sm text-text-muted leading-relaxed">{s.body}</p>
            </div>
          </li>
        ))}
      </ul>

      <div class="mt-3 flex items-center justify-between gap-3 md:hidden">
        <p class="text-[11px] uppercase tracking-widest text-text-muted">Swipe →</p>
        <div class="flex items-center gap-1.5">
          <span class="h-1 w-6 rounded-full bg-brand"></span>
          <span class="h-1 w-3 rounded-full bg-border-subtle"></span>
          <span class="h-1 w-3 rounded-full bg-border-subtle"></span>
        </div>
      </div>
    </div>
  </div>
</section>
