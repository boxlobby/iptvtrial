---
import Icon from './Icon.astro';
import Placeholder from './Placeholder.astro';
import { site, waLink } from '../data/site';
---
<section class="grid-bg relative overflow-hidden">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute -top-40 left-1/2 h-[500px] w-[800px] -translate-x-1/2 rounded-full bg-brand/15 blur-3xl"></div>
    <div class="absolute top-40 -right-20 h-[300px] w-[300px] rounded-full bg-accent/10 blur-3xl"></div>
  </div>

  <div class="container-x pt-14 sm:pt-20 md:pt-24 pb-10 sm:pb-16 text-center">
    <span class="eyebrow mb-5">
      <span class="h-1.5 w-1.5 rounded-full bg-brand animate-pulse"></span>
      Made for UK viewers
    </span>

    <h1 class="mx-auto max-w-4xl text-[2rem] sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.08]">
      <span class="text-text-primary">IPTV Trial UK, </span>
      <span class="bg-grad-brand bg-clip-text text-transparent">30 Days for {site.currencySymbol}{site.price}</span>
    </h1>

    <p class="mx-auto mt-5 max-w-2xl text-base sm:text-lg md:text-xl text-text-muted leading-relaxed px-2">
      Try the UK’s fastest IPTV service risk-free with a full 30-day IPTV subscription. <strong class="text-text-primary">50,000+ live channels</strong>
      plus thousands of movies and series in 4K, on any device, activated in minutes.
    </p>

    <div class="mt-7 flex justify-center max-w-md sm:max-w-none mx-auto">
      <a href={waLink()} class="btn-primary text-base px-8 py-4" target="_blank" rel="nofollow noopener noreferrer">
        Get My Trial, {site.currencySymbol}{site.price}
        <Icon name="arrow" size={18} />
      </a>
    </div>

    <ul class="mt-8 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-xs sm:text-sm text-text-muted">
      <li class="flex items-center gap-1.5"><Icon name="clock" class="text-accent" size={15} /> 30-day trial</li>
      <li class="flex items-center gap-1.5"><Icon name="zap" class="text-accent" size={15} /> Instant activation</li>
      <li class="flex items-center gap-1.5"><Icon name="shield" class="text-accent" size={15} /> VPN Protected</li>
    </ul>

    <div class="mt-10 sm:mt-14 mx-auto max-w-4xl">
      <div class="rounded-2xl border border-border-subtle bg-elevated/60 p-2 shadow-glow-lg">
        <Placeholder
          src="https://cdn.ukiptvbox.com/Men_watching_football_match_202607200445.webp"
          alt="Men watching a live football match with an IPTV TRIAL streaming service on TV"
          aspect="aspect-video"
          eager
          width={1280}
          height={720}
          sizes="(min-width: 1024px) 896px, (min-width: 640px) calc(100vw - 3rem), calc(100vw - 2rem)"
        />
      </div>
    </div>
  </div>

  <div class="mt-10 sm:mt-14 border-y border-border-subtle bg-elevated/30">
    <div class="container-x">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-border-subtle">
        <div class="py-8 sm:py-10 px-4 text-center">
          <div class="text-3xl sm:text-4xl md:text-5xl font-bold bg-grad-brand bg-clip-text text-transparent whitespace-nowrap" data-count-up data-target="50000" data-suffix="+">0+</div>
          <div class="mt-2 text-[0.7rem] sm:text-xs tracking-widest uppercase text-text-muted">Live Channels</div>
        </div>
        <div class="py-8 sm:py-10 px-4 text-center">
          <div class="text-3xl sm:text-4xl md:text-5xl font-bold bg-grad-brand bg-clip-text text-transparent whitespace-nowrap" data-count-up data-target="200000" data-suffix="+">0+</div>
          <div class="mt-2 text-[0.7rem] sm:text-xs tracking-widest uppercase text-text-muted">Movies &amp; Series</div>
        </div>
        <div class="py-8 sm:py-10 px-4 text-center">
          <div class="text-2xl sm:text-3xl md:text-4xl font-bold bg-grad-brand bg-clip-text text-transparent whitespace-nowrap">Buffer-Free</div>
          <div class="mt-2 text-[0.7rem] sm:text-xs tracking-widest uppercase text-text-muted">Stable Streaming</div>
        </div>
        <div class="py-8 sm:py-10 px-4 text-center">
          <div class="text-3xl sm:text-4xl md:text-5xl font-bold bg-grad-brand bg-clip-text text-transparent whitespace-nowrap">4K</div>
          <div class="mt-2 text-[0.7rem] sm:text-xs tracking-widest uppercase text-text-muted">Ultra HD Quality</div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const formatNumber = (n: number) => n.toLocaleString('en-GB');

  const animate = (el: HTMLElement) => {
    const target = parseInt(el.dataset.target || '0', 10);
    const suffix = el.dataset.suffix || '';
    const prefix = el.dataset.prefix || '';
    const duration = parseInt(el.dataset.duration || '2000', 10);
    const start = performance.now();

    const tick = (now: number) => {
      const p = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      const value = Math.floor(eased * target);
      el.textContent = `${prefix}${formatNumber(value)}${suffix}`;
      if (p < 1) requestAnimationFrame(tick);
      else el.textContent = `${prefix}${formatNumber(target)}${suffix}`;
    };
    requestAnimationFrame(tick);
  };

  const els = document.querySelectorAll<HTMLElement>('[data-count-up]');
  if (els.length) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          if (!el.dataset.counted) {
            el.dataset.counted = '1';
            animate(el);
          }
          io.unobserve(el);
        }
      });
    }, { threshold: 0.3 });
    els.forEach((el) => io.observe(el));
  }
</script>
