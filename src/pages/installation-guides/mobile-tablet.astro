---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Icon from '../../components/Icon.astro';
import FinalCta from '../../components/FinalCta.astro';
import { site, waLink } from '../../data/site';

const canonical = `${site.url}/installation-guides/mobile-tablet/`;
const ogImage = 'https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/Mobile_IPTV_Apps_2026_devices_202607210425.jpeg';
const publishedFmt = '20 July 2026';
const updatedFmt = '20 July 2026';

type App = {
  slug: string;
  name: string;
  tag: 'free' | 'paid';
  price?: string;
  logo: string;
  login: string;
  supported: string;
  activateUrl?: string;
  copy: string;
  steps: { title: string; body: string }[];
  tips?: string[];
};

const apps: App[] = [
  {
    slug: 'hot',
    name: 'Hot Player / Hot IPTV',
    tag: 'paid',
    price: '€5.99/yr · €14.99 lifetime · 30-day free trial',
    logo: 'https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/hot-player.webp',
    login: 'M3U playlist URL (uploaded at hotplayer.app/upload)',
    supported: 'iOS 13+ · iPadOS · Android 6+ · Android tablets · Fire tablets',
    activateUrl: 'https://hotplayer.app/activation',
    copy: `Hot Player is our #1 pick for a mobile iptv trial in 2026. It has the longest free trial of any mainstream mobile IPTV app — a full 30 days — which means you can test our iptv uk trial on your iPhone, iPad or Android device for the entire first month before paying a penny for the player. The interface is finger-friendly with big posters, a fast EPG, cross-device sync and background audio for radio channels. One paid unlock (€14.99 lifetime) covers the app forever on that device.`,
    steps: [
      { title: 'Install Hot Player on your phone or tablet', body: 'Open the App Store (iPhone / iPad) or Google Play (Android) and search "Hot Player" or "Hot IPTV". Install the free app. On iPad tap the Get button, on Android tap Install — no sideloading needed.' },
      { title: 'Open the app and note your MAC / device ID', body: 'Launch Hot Player. The welcome screen shows a MAC-style device ID unique to your phone or tablet. Screenshot it — this is what we attach your playlist to.' },
      { title: 'Send us your MAC on WhatsApp', body: `WhatsApp us the MAC together with your order name. We generate a personal M3U playlist URL against your iptv subscription and reply within a few minutes.` },
      { title: 'Upload the playlist at hotplayer.app/upload', body: 'On the same phone or another device open hotplayer.app/upload in a browser, enter your MAC and paste the M3U URL we sent you. Save the changes.' },
      { title: 'Reload Hot Player and start streaming', body: 'Force-close Hot Player and re-open it. Your full UK channel list, sports, films and series load automatically with EPG. You have 30 days free — activate on hotplayer.app/activation when the trial ends.' },
    ],
    tips: [
      "Don\'t confuse the two Hot Player URLs: /upload is where you paste your playlist during the free 30 days, /activation is where you pay if you want to keep the app after that.",
      'Hot Player syncs your playlist across devices — install it on both your phone and your tablet and log in with the same email to get a unified favourites list.',
    ],
  },
  {
    slug: 'ibo',
    name: 'IBO Player Pro',
    tag: 'paid',
    price: '≈ €8 lifetime · 7-day free trial',
    logo: 'https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/ibo-player.webp',
    login: 'Device Key + MAC (activated on iboproapp.com)',
    supported: 'iOS 13+ · iPadOS · Android 6+ · Fire tablets',
    activateUrl: 'https://iboproapp.com',
    copy: `IBO Player Pro is the most polished paid mobile IPTV player and the one we recommend if you want a Netflix-style interface on an iPad or larger Android tablet. It comes with a 7-day free trial baked in — enough to properly test our iptv uk trial — and one payment of about €8 unlocks the app for life on that device. Category posters, a fast EPG, catch-up support and picture-in-picture playback on iPad are all built in.`,
    steps: [
      { title: 'Install IBO Player Pro', body: 'From the App Store (iPhone / iPad) or Google Play (Android) search "IBO Player Pro" and install. On older phones it may appear simply as "IBO Player".' },
      { title: 'Read your Device Key and MAC', body: 'Open the app. The first screen shows a Device Key AND a MAC address. You\'ll need both — take a screenshot.' },
      { title: 'Send us both codes', body: 'WhatsApp us the Device Key and MAC. We upload your playlist against them and confirm when it\'s live, usually within 10 minutes.' },
      { title: 'Enjoy the free trial, then activate', body: 'You get 7 days completely free. To keep the app after that, visit iboproapp.com, enter the same Device Key + MAC and pay the one-off €8 lifetime fee. Your playlist and settings stay exactly as they are.' },
    ],
    tips: [
      'IBO Player Pro payment is handled by IBO directly on iboproapp.com — completely separate from your iptv subscription with us.',
      'iPad users: enable "Picture-in-Picture" in iOS Settings → IBO Player Pro to keep watching football while you scroll other apps.',
    ],
  },
  {
    slug: 'smarters',
    name: 'IPTV Smarters Pro',
    tag: 'free',
    logo: 'https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/iptv-smarters.webp',
    login: 'Xtream Codes API (username + password + server URL)',
    supported: 'iOS 13+ · iPadOS · Android 6+ · Android tablets',
    copy: `IPTV Smarters Pro is the free, universal mobile IPTV app used by nearly every UK iptv service — including ours. It logs in directly with Xtream Codes (the same username, password and server URL we send to Fire Stick and Apple TV users) so there\'s no MAC upload, no waiting, and no payment to the app developer. It\'s the fastest way to get an iptv trial running on a phone or tablet in under 60 seconds.`,
    steps: [
      { title: 'Install IPTV Smarters Pro', body: 'On Android open Google Play and search "IPTV Smarters Pro" — install the free app by WHMCS SMARTERS. On iPhone / iPad open the App Store and search the same — if it\'s missing from your regional store, install "Smarters Player Lite" instead (it works identically).' },
      { title: 'Choose Login with Xtream Codes API', body: 'Open the app, accept the terms and tap Add New User. On the next screen pick "Login with Xtream Codes API" — the fastest, most reliable login method for any iptv subscription.' },
      { title: 'Enter the credentials we sent you', body: 'Type any nickname (e.g. "iPhone"), then paste the username, password and server URL from your welcome message. Tap Add User.' },
      { title: 'Start streaming', body: 'The app connects instantly and downloads your live channels, films, series and EPG. Everything is touch-optimised and works over Wi-Fi, 4G or 5G.' },
    ],
    tips: [
      'On iOS, if IPTV Smarters Pro is delisted in your region, "Smarters Player Lite" is the exact same app under a different name — install that instead.',
      'Enable "External Player" in Settings and pick VLC if a specific channel refuses to open — a codec quirk, not a stream problem.',
    ],
  },
];

const faqs = [
  {
    q: 'Which is the best IPTV app for iPhone and Android in 2026?',
    a: 'For a mobile iptv trial we rank them in this order: Hot Player first because of its 30-day free trial and cross-device sync, IBO Player Pro second for its Netflix-style interface (7-day free trial, €8 lifetime), and IPTV Smarters Pro third as the free universal option. All three work with our iptv uk trial and all three run on iPhone, iPad, Android phones and Android tablets.',
  },
  {
    q: 'Do I need a paid IPTV app on my phone or tablet?',
    a: 'No. IPTV Smarters Pro is completely free on both the App Store and Google Play. Hot Player and IBO Player Pro come with free trials (30 days and 7 days respectively) — you can install them, paste your playlist and test them properly before paying anything. Payment for the paid apps is handled on their own official sites (hotplayer.app/activation, iboproapp.com) and is separate from your iptv subscription with us.',
  },
  {
    q: 'Can I use my iptv subscription on both my phone and my Smart TV?',
    a: `Yes — every ${site.name} iptv subscription includes multi-device access. You can run IPTV Smarters Pro on your iPhone at the gym, IBO Player Pro on your iPad in bed, and XOTT or Hot Player on your Smart TV in the living room, all against the same iptv trial. See our Smart TV installation guide for the TV-side setup.`,
  },
  {
    q: 'How do I install IPTV Smarters Pro on iOS if it\'s missing from the App Store?',
    a: 'Some Apple regions have delisted "IPTV Smarters Pro". If yours has, install "Smarters Player Lite" from the App Store instead — it\'s the exact same app under a different name, made by the same developer, and accepts the same Xtream Codes credentials we send you. On an iPad you can also install IBO Player Pro or Hot Player as alternatives.',
  },
  {
    q: 'Does mobile IPTV support 4K on tablets?',
    a: 'Yes. Hot Player, IBO Player Pro and IPTV Smarters Pro all support 4K HEVC/H.265 playback on any modern iPhone (11 or newer), iPad Pro, Fire tablet or Android tablet with a 4K screen. For the smoothest 4K experience on the go, use Wi-Fi 6 or a 5G connection with at least 25 Mbps down.',
  },
  {
    q: 'How long does the mobile IPTV setup take?',
    a: `Under 5 minutes end-to-end. You install one app from the App Store or Google Play (30 seconds), open it (10 seconds), either paste the Xtream Codes credentials we send you (IPTV Smarters Pro — instant) or WhatsApp us your MAC / Device Key so we can upload your playlist (Hot Player, IBO Player Pro — 2 to 10 minutes on our side). That\'s the exact process every ${site.name} iptv uk trial customer follows on their phone or tablet.`,
  },
  {
    q: 'Is a mobile iptv service safe to use on 4G or 5G?',
    a: 'Yes — our iptv service streams over standard HTTPS on the same ports as YouTube or Netflix, so it works on any UK 4G / 5G network without special setup. If your mobile carrier throttles video, enable the app\'s built-in "low bandwidth" mode or connect through a personal Wi-Fi hotspot. For unlimited data plans the iptv trial runs perfectly on the tube, on trains and abroad.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.url}/` },
        { '@type': 'ListItem', position: 2, name: 'Installation Guides', item: `${site.url}/installation-guides/` },
        { '@type': 'ListItem', position: 3, name: 'Mobile & Tablet', item: canonical },
      ],
    },
    {
      '@type': 'Article',
      headline: 'How to install IPTV on iPhone, iPad and Android — 3 best mobile apps ranked',
      description: 'The complete mobile IPTV setup guide for iPhone, iPad, Android phones and Android tablets. Compares Hot Player, IBO Player Pro and IPTV Smarters Pro — the top 3 IPTV apps for a mobile iptv trial.',
      image: ogImage,
      author: { '@type': 'Organization', name: `${site.name} Editorial`, url: site.url },
      publisher: {
        '@type': 'Organization',
        name: site.name,
        url: site.url,
        logo: { '@type': 'ImageObject', url: `${site.url}/og-image.svg` },
      },
      datePublished: '2026-07-20',
      dateModified: '2026-07-20',
      mainEntityOfPage: canonical,
      articleSection: 'IPTV Installation Guides',
      keywords: 'iptv trial, iptv uk trial, iptv subscriptions, iptv subscription, iptv service, mobile iptv, iphone iptv, android iptv, ipad iptv, hot player, ibo player pro, iptv smarters pro',
    },
    {
      '@type': 'HowTo',
      name: 'How to install IPTV on a phone or tablet',
      totalTime: 'PT5M',
      step: apps.flatMap((app) => app.steps.map((s, i) => ({
        '@type': 'HowToStep',
        name: `${app.name} — ${s.title}`,
        text: s.body,
        position: i + 1,
      }))),
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};

const relatedGuides = [
  { slug: 'smart-tv', label: 'Set up IPTV on a Smart TV', device: 'Smart TV' },
  { slug: 'firestick', label: 'Set up IPTV on Fire Stick', device: 'Fire Stick' },
  { slug: 'apple-tv', label: 'Set up IPTV on Apple TV', device: 'Apple TV' },
  { slug: 'windows-mac', label: 'Set up IPTV on Windows or Mac', device: 'Windows & Mac' },
];
---
<BaseLayout
  title={`Mobile IPTV setup — 3 best iPhone & Android apps (2026) | ${site.name}`}
  description="Install IPTV on any Android phone, iPhone, iPad or tablet in under 5 minutes. Step-by-step guide to Hot Player, IBO Player Pro and IPTV Smarters Pro — the top 3 mobile IPTV apps for your iptv uk trial."
  canonical={canonical}
  ogImage={ogImage}
  includeSchema={false}
>
  <Header />
  <main id="main">
    <!-- Hero -->
    <section class="relative overflow-hidden border-b border-border-subtle">
      <div class="pointer-events-none absolute inset-0 -z-10 opacity-70">
        <div class="absolute -top-40 left-1/2 h-[560px] w-[900px] -translate-x-1/2 rounded-full bg-grad-brand-soft blur-3xl"></div>
      </div>
      <div class="container-x pt-14 pb-12 md:pt-20 md:pb-16 max-w-3xl">
        <nav aria-label="Breadcrumb" class="text-xs uppercase tracking-widest text-text-muted">
          <a href="/" class="hover:text-brand-light">Home</a>
          <span class="mx-2 text-border-subtle">/</span>
          <a href="/installation-guides/" class="hover:text-brand-light">Installation Guides</a>
          <span class="mx-2 text-border-subtle">/</span>
          <span class="text-text-primary">Mobile & Tablet</span>
        </nav>

        <div class="mt-6 flex items-center gap-4">
          <span class="flex h-14 w-14 items-center justify-center rounded-xl border border-brand/20 bg-brand/10 text-brand-light">
            <Icon name="smartphone" size={28} />
          </span>
          <div>
            <p class="text-[11px] font-semibold uppercase tracking-widest text-text-muted">
              6 min read · Step-by-step
            </p>
            <span class="eyebrow mt-1 block">Mobile & tablet setup</span>
          </div>
        </div>

        <h1 class="mt-6 font-display text-3xl md:text-5xl font-bold tracking-tight text-text-primary">
          Mobile IPTV — 3 best apps for Android, iOS, iPad & tablets (2026)
        </h1>
        <p class="mt-5 text-lg text-text-muted leading-relaxed">
          Install IPTV on any iPhone, iPad, Android phone or Android tablet in under 5 minutes.
          This guide walks through the three mobile apps we actively support for a UK
          <strong>iptv trial</strong> — <strong>Hot Player</strong>, <strong>IBO Player Pro</strong>
          and <strong>IPTV Smarters Pro</strong> — all compatible with our
          <a href="/#pricing" class="text-brand-light underline underline-offset-4 decoration-brand/40 hover:decoration-brand-light">£{site.price} iptv uk trial</a>
          and multi-device iptv subscriptions.
        </p>

        <p class="mt-6 inline-flex items-center gap-2 text-xs uppercase tracking-widest text-text-muted">
          <span class="h-1.5 w-1.5 rounded-full bg-brand-light"></span>
          Published {publishedFmt} · Updated {updatedFmt}
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href={waLink(`Hi, I'd like to start my £${site.price} IPTV trial on my phone / tablet.`)} class="btn-primary" target="_blank" rel="nofollow noopener noreferrer">
            Start £{site.price} IPTV trial
          </a>
          <a href="#apps" class="btn-secondary">Choose an app</a>
        </div>

        <figure class="mt-10 overflow-hidden rounded-2xl border border-border-subtle bg-elevated/60">
          <img
            src="https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/Mobile_IPTV_Apps_2026_devices_202607210425.jpeg"
            alt="Mobile IPTV setup — Hot Player, IBO Player Pro and IPTV Smarters Pro on iPhone, iPad and Android"
            width="1200"
            height="630"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="w-full h-auto"
            onerror="this.src='/installation-guides/smart-tv-hero.svg'"
          />
        </figure>
      </div>
    </section>

    <!-- Body -->
    <section class="container-x py-14 md:py-20 max-w-3xl is-visible" data-reveal="fade">
      <article class="legal-prose">
        <p>
          Every modern iPhone, iPad and Android phone can run <strong>IPTV</strong> without extra
          hardware — you just need to pick the right player app. This guide covers the three mobile
          apps we recommend for anyone starting a UK <strong>iptv subscription</strong> or testing
          our iptv service on the go. Whichever app you pick, the activation flow is the same:
          install it from the App Store or Google Play, either enter the Xtream Codes credentials
          we send you or WhatsApp us your device MAC, and start streaming. That's it.
        </p>

        <p>Short on time? The three apps that cover 100% of mobile IPTV setups:</p>
        <ul>
          <li><a href="#hot"><strong>Hot Player / Hot IPTV</strong></a> — 30-day free trial, the best pairing with a monthly iptv uk trial</li>
          <li><a href="#ibo"><strong>IBO Player Pro</strong></a> — ≈€8 lifetime, 7-day free trial, the most polished paid iPad app</li>
          <li><a href="#smarters"><strong>IPTV Smarters Pro</strong></a> — 100% free, Xtream Codes login, the fastest to set up</li>
        </ul>
      </article>

      <!-- Paid apps callout -->
      <div class="mt-10 rounded-2xl border border-brand/25 bg-brand/5 p-5 md:p-6">
        <div class="flex items-start gap-3">
          <span class="mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand/15 text-brand-light">
            <Icon name="sparkles" size={16} />
          </span>
          <div class="min-w-0">
            <p class="font-semibold text-text-primary">About the paid apps</p>
            <p class="mt-2 text-sm text-text-muted leading-relaxed">
              Hot Player and IBO Player Pro each come with a <span class="text-brand-light font-medium">free trial</span> — install one, paste your playlist and test it properly.
              When the trial ends, you activate (pay for) the app on its <strong>own official site</strong> below. Tap any app card for its exact steps.
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              <a href="https://hotplayer.app/activation" target="_blank" rel="nofollow noopener noreferrer" class="btn-secondary text-xs">Activate Hot Player / Hot IPTV ↗</a>
              <a href="https://iboproapp.com" target="_blank" rel="nofollow noopener noreferrer" class="btn-secondary text-xs">Activate IBO Player Pro ↗</a>
            </div>
          </div>
        </div>
      </div>

      <!-- App selector list -->
      <h2 id="apps" class="mt-16 font-display text-2xl md:text-3xl font-bold text-text-primary scroll-mt-24">
        Choose an app
      </h2>
      <p class="mt-3 text-text-muted">
        Tap any app to jump to its full step-by-step mobile IPTV setup.
      </p>
      <ul class="mt-6 space-y-3">
        {apps.map((app) => (
          <li>
            <a
              href={`#${app.slug}`}
              class="card group flex items-center gap-4 p-4 transition hover:border-brand/50"
            >
              <img
                src={app.logo}
                alt={`${app.name} logo`}
                width="48"
                height="48"
                loading="lazy"
                decoding="async"
                class="h-12 w-12 shrink-0 rounded-xl border border-border-subtle bg-elevated"
                onerror="this.src='/og-image.svg'"
              />
              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="text-base font-semibold text-text-primary group-hover:text-brand-light">{app.name}</span>
                  {app.tag === 'free' ? (
                    <span class="rounded-full border border-emerald-400/40 bg-emerald-400/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-emerald-300">Free</span>
                  ) : (
                    <span class="rounded-full border border-amber-400/40 bg-amber-400/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-amber-300">Paid app</span>
                  )}
                  {app.price && (
                    <span class="rounded-full border border-border-subtle bg-elevated/60 px-2 py-0.5 text-[10px] text-text-muted">
                      {app.price}
                    </span>
                  )}
                </div>
                <p class="mt-1 text-xs text-text-muted line-clamp-1">{app.supported}</p>
              </div>
              <span class="text-brand-light shrink-0"><Icon name="chevron-right" size={18} /></span>
            </a>
          </li>
        ))}
      </ul>

      <!-- Per-app deep cards -->
      <div class="mt-14 space-y-14">
        {apps.map((app, idx) => (
          <article id={app.slug} class="card p-6 md:p-8 scroll-mt-24">
            <div class="flex items-start gap-4">
              <img
                src={app.logo}
                alt={`${app.name} logo`}
                width="72"
                height="72"
                loading="lazy"
                decoding="async"
                class="h-16 w-16 md:h-[72px] md:w-[72px] shrink-0 rounded-2xl border border-border-subtle bg-elevated"
                onerror="this.src='/og-image.svg'"
              />
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <p class="text-[11px] font-semibold uppercase tracking-widest text-brand-light">
                    App {idx + 1} of {apps.length}
                  </p>
                  {app.tag === 'free' ? (
                    <span class="rounded-full border border-emerald-400/40 bg-emerald-400/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-emerald-300">Free</span>
                  ) : (
                    <span class="rounded-full border border-amber-400/40 bg-amber-400/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-amber-300">Paid app</span>
                  )}
                </div>
                <h2 class="mt-1 font-display text-2xl md:text-[28px] font-bold text-text-primary">
                  {app.name}
                </h2>
                {app.price && (
                  <p class="mt-1 text-sm text-text-muted">{app.price}</p>
                )}
              </div>
            </div>

            <p class="mt-6 text-text-muted leading-relaxed">{app.copy}</p>

            <div class="mt-6 grid gap-4 sm:grid-cols-2">
              <div class="rounded-xl border border-border-subtle bg-elevated/50 p-4">
                <p class="text-[11px] font-semibold uppercase tracking-widest text-text-muted">Log in via</p>
                <p class="mt-1 text-sm text-text-primary">{app.login}</p>
              </div>
              <div class="rounded-xl border border-border-subtle bg-elevated/50 p-4">
                <p class="text-[11px] font-semibold uppercase tracking-widest text-text-muted">Supported devices</p>
                <p class="mt-1 text-sm text-text-primary">{app.supported}</p>
              </div>
            </div>

            <h3 class="mt-8 font-display text-lg md:text-xl font-semibold text-text-primary">Step-by-step</h3>
            <ol class="mt-4 space-y-4">
              {app.steps.map((s, i) => (
                <li class="flex gap-4">
                  <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-grad-brand text-xs font-bold text-white shadow-glow">
                    {i + 1}
                  </span>
                  <div class="min-w-0">
                    <p class="text-sm md:text-base font-semibold text-text-primary">{s.title}</p>
                    <p class="mt-1 text-sm text-text-muted leading-relaxed">{s.body}</p>
                  </div>
                </li>
              ))}
            </ol>

            {app.tips && app.tips.length > 0 && (
              <div class="mt-6 rounded-xl border border-brand/25 bg-brand/5 p-4">
                <p class="text-[11px] font-semibold uppercase tracking-widest text-brand-light">Tips</p>
                <ul class="mt-2 space-y-1.5 text-sm text-text-muted">
                  {app.tips.map((t) => (
                    <li class="flex gap-2">
                      <span class="mt-1 inline-flex h-4 w-4 shrink-0 items-center justify-center text-brand-light">
                        <Icon name="check" size={14} />
                      </span>
                      <span set:html={t}></span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <div class="mt-6 flex flex-wrap gap-3">
              <a
                href={waLink(`Hi, I'd like to set up ${app.name} on my phone / tablet with your £${site.price} IPTV trial.`)}
                class="btn-primary"
                target="_blank"
                rel="nofollow noopener noreferrer"
              >
                Activate my {app.name}
              </a>
              {app.activateUrl && (
                <a href={app.activateUrl} target="_blank" rel="nofollow noopener noreferrer" class="btn-secondary">
                  Official site ↗
                </a>
              )}
            </div>
          </article>
        ))}
      </div>

      <!-- Comparison -->
      <h2 id="comparison" class="mt-16 font-display text-2xl md:text-3xl font-bold text-text-primary scroll-mt-24">
