              <td class="p-3">Intermediate</td>
              <td class="p-3">≈ 5 min</td>
              <td class="p-3">M3U URL</td>
              <td class="p-3">Free</td>
            </tr>
            <tr class="border-t border-border-subtle/60">
              <td class="p-3 text-text-primary font-medium">Ministra TV</td>
              <td class="p-3">Intermediate</td>
              <td class="p-3">≈ 5 min</td>
              <td class="p-3">Ministra URL</td>
              <td class="p-3">Included</td>
