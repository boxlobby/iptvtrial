        <div class="mt-6">
          <a href={waLink(`Hi, I need help setting up IPTV on my Enigma2 / Formuler box. My box model is:`)} class="btn-primary" target="_blank" rel="nofollow noopener noreferrer">
            <Icon name="whatsapp" size={16} class="mr-2" />
