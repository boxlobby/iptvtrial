---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Icon from '../../components/Icon.astro';
import FinalCta from '../../components/FinalCta.astro';
import { site, waLink } from '../../data/site';

const canonical = `${site.url}/installation-guides/apple-tv/`;
const ogImage = 'https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/Apple_TV_IPTV_guide_2026_202607210427.jpeg';
const publishedFmt = '20 July 2026';
const updatedFmt = '20 July 2026';

type App = {
  slug: string;
  name: string;
  tag: 'free' | 'paid';
  price?: string;
  logo: string;
  login: string;
  supported: string;
  activateUrl?: string;
  copy: string;
  steps: { title: string; body: string }[];
  tips?: string[];
};

const apps: App[] = [
  {
    slug: 'smarters-lite',
    name: 'Smarters Player Lite',
    tag: 'free',
    logo: 'https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/iptv-smarters.webp',
    login: 'Xtream Codes API (username + password + server URL) or M3U URL',
    supported: 'Apple TV HD (4th gen) · Apple TV 4K (all generations) · iPhone · iPad',
    activateUrl: 'https://apps.apple.com/us/app/smarters-player-lite/id1628995509',
    copy: `Smarters Player Lite is the free go-to IPTV player on Apple TV and the app we recommend every new ${site.name} customer install first. It's a native tvOS build — installs directly from the App Store, no sideloading required (Apple TV doesn't allow it anyway) — and it logs in with the exact same Xtream Codes username, password and server URL we send in your welcome message. Perfect first stop for your iptv trial.`,
    steps: [
      { title: 'Open the tvOS App Store', body: 'From the Apple TV home screen open the App Store, hit the search icon (top right) and type "Smarters Player Lite". Select the orange Smarters icon by WHMCS Smarters.' },
      { title: 'Install with your Apple ID', body: 'Click Get. If prompted, confirm with your Apple ID password or double-click the Siri Remote side button for Face ID / Touch ID on iPhone. The app is 100% free — no in-app purchases required.' },
      { title: 'Add a new user', body: 'Open Smarters Player Lite → Accept the terms → "Add New User" → "Login with Xtream Codes API". This is the fastest method and the one your iptv subscription with us uses.' },
      { title: 'Enter your details', body: 'Any name you like (e.g. "Living Room"), then paste the username, password and server URL from your WhatsApp welcome message. Press Add. Your channels, VOD and series load in seconds.' },
      { title: 'Start streaming in 4K HDR', body: 'You\'ll land on a home screen with Live TV, Movies, Series and TV Guide tiles. Swipe the Siri Remote touchpad to jump between UK, USA, sports and film categories. 4K HDR playback is on by default on any Apple TV 4K.' },
    ],
    tips: ['If Smarters Player Lite ever disappears from your regional App Store, install "IPTV Smarters Player Expert" instead — same developer, same Xtream Codes login, same iptv service credentials work with zero changes.'],
  },
  {
    slug: 'smarters-expert',
    name: 'IPTV Smarters Player Expert',
    tag: 'paid',
    price: '$1.99 one-off',
    logo: 'https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/iptv-smarters.webp',
    login: 'Xtream Codes API or M3U URL',
    supported: 'Apple TV HD (4th gen) · Apple TV 4K (all generations) · iPhone · iPad',
    activateUrl: 'https://apps.apple.com/us/app/iptv-smarters-player-expert/id1641944027',
    copy: `IPTV Smarters Player Expert is the paid tvOS sibling of Smarters Player Lite — same login, same interface, but with multi-user support, faster channel switching and priority updates. A tiny one-off $1.99 pays for it forever on your Apple ID (works on every Apple TV signed into that ID). A worthwhile upgrade if you use your iptv subscription every night.`,
    steps: [
      { title: 'Search the App Store', body: 'Apple TV → App Store → search "IPTV Smarters Player Expert". Select the icon by WHMCS Smarters.' },
      { title: 'Buy for $1.99', body: 'Click the price, confirm with Apple ID. The purchase is tied to your Apple ID, not the specific Apple TV — install it on every Apple TV you own at no extra cost.' },
      { title: 'Add a new user', body: 'Open the app → Add New User → Login with Xtream Codes API. Enter the username, password and server URL we sent you.' },
      { title: 'Enable multi-user (optional)', body: 'Settings → Users → Add another profile if a family member has a separate iptv uk trial. Each profile has its own favourites, EPG and parental settings.' },
      { title: 'Start streaming', body: 'The channel grid loads immediately. Long-press the Siri Remote to open the on-screen EPG, and use "Match Content" (Apple TV → Settings → Video and Audio) for automatic HDR / 50Hz switching on sport.' },
    ],
    tips: ['Same Xtream Codes credentials as Smarters Player Lite — you can migrate from Lite to Expert without contacting us and everything just works.'],
  },
  {
    slug: 'iplaytv',
    name: 'iPlayTV',
    tag: 'paid',
    price: '£5.99 one-off',
    logo: 'https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/iplaytv.jpg',
    login: 'M3U URL or Xtream Codes API',
    supported: 'Apple TV HD (4th gen) · Apple TV 4K (all generations) · iPhone · iPad',
    activateUrl: 'https://apps.apple.com/gb/app/iplaytv/id1072226801',
    copy: `iPlayTV is the most polished paid IPTV app on tvOS — Netflix-style poster art, native EPG, AirPlay 2, background audio and buttery Siri Remote navigation. A one-off £5.99 unlocks it for life on your Apple ID. If you want an Apple-quality interface for your iptv service, this is the app to pick.`,
    steps: [
      { title: 'Buy iPlayTV on the App Store', body: 'Apple TV → App Store → search "iPlayTV" (by NetRange MMH GmbH). Pay the one-off £5.99 with your Apple ID.' },
      { title: 'Open and choose Add Playlist', body: 'Launch iPlayTV → hit the "+" tile → choose "Remote Playlist File" (for M3U) or "Xtream Codes" if you prefer username/password login.' },
      { title: 'Enter your playlist details', body: 'Name it (e.g. "IPTV UK"), then either paste the M3U URL we sent you, or enter the Xtream Codes host, username and password. Save.' },
      { title: 'Wait for the EPG', body: 'iPlayTV downloads the electronic programme guide in the background — usually 30–60 seconds for a full UK line-up. The channel grid populates as it goes.' },
      { title: 'Enable 4K HDR + AirPlay', body: 'Settings → Video → set stream quality to Auto (or 4K on Apple TV 4K). Enable AirPlay from the "..." menu on any channel to beam to a second Apple TV or HomePod.' },
    ],
    tips: ['iPlayTV is one of the very few tvOS apps to support catch-up TV (timeshift) — if your iptv subscription includes catch-up, iPlayTV surfaces it automatically as "Rewind" on each channel.'],
  },
  {
    slug: 'gse',
    name: 'GSE Smart IPTV',
    tag: 'paid',
    price: 'Free tier · Pro ≈ £4.99',
    logo: 'https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/unnamed-2.png',
    login: 'M3U URL · Xtream Codes API · XMLTV EPG',
    supported: 'Apple TV HD (4th gen) · Apple TV 4K (all generations) · iPhone · iPad · Mac',
    activateUrl: 'https://apps.apple.com/gb/search?term=gse+smart+iptv',
    copy: `GSE Smart IPTV is the most feature-complete IPTV player on Apple TV — multi-EPG, custom stream headers, multiple video decoders (native / VLC / IJKPlayer), picture-in-picture, external player support and per-playlist parental locks. Free tier has ads; the one-off Pro upgrade (~£4.99) removes them. The right pick if you also run non-UK iptv subscriptions alongside your ${site.name} one.`,
    steps: [
      { title: 'Install GSE Smart IPTV', body: 'Apple TV → App Store → search "GSE Smart IPTV" (by 7net Solutions). Install the free version to start — you can upgrade to Pro from inside the app later.' },
      { title: 'Open Playlist Manager', body: 'Launch the app → open the side menu → "Xtream Codes API" (or "Remote Playlists" for M3U). Choose "Add".' },
      { title: 'Enter your credentials', body: 'Name it (e.g. "IPTV UK Trial"), then paste the host URL, username and password we sent you. Save.' },
      { title: 'Pick a video decoder', body: 'Settings → Player → Video Player. Native works best on Apple TV 4K for HEVC; switch to VLC if any specific channel refuses to play (a codec fallback trick specific to tvOS).' },
      { title: 'Upgrade to Pro (optional)', body: 'Settings → Upgrade to Pro. One-off ~£4.99 removes ads and unlocks unlimited playlists — useful if you juggle multiple iptv subscriptions.' },
    ],
    tips: ['If a stream stutters on Apple TV 4K, open the channel and change Decoder from "Native" to "IJKPlayer" — solves 90% of HEVC / 10-bit playback quirks.'],
  },
  {
    slug: 'iptvx',
    name: 'IPTVX',
    tag: 'paid',
    price: '≈ £4.99 one-off',
    logo: 'https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/iptvx.webp',
    login: 'M3U URL or Xtream Codes API',
    supported: 'Apple TV HD (4th gen) · Apple TV 4K (all generations) · iPhone · iPad',
    activateUrl: 'https://apps.apple.com/gb/search?term=iptvx',
    copy: `IPTVX feels like an app Apple would have built themselves — the cleanest interface, the fastest zapping and the most tasteful use of poster art on tvOS. A one-off ≈£4.99 (occasionally free during promotions) unlocks it for life. The connoisseur's choice for a premium iptv service.`,
    steps: [
      { title: 'Install IPTVX on Apple TV', body: 'App Store → search "IPTVX". Buy the one-off unlock (or grab it free during a promo). Install and launch.' },
      { title: 'Add a playlist', body: 'On first launch tap "Add Playlist" → choose Xtream Codes (recommended) or M3U URL. Give it a nickname.' },
      { title: 'Paste your login', body: 'For Xtream Codes: enter the server URL, username and password from your welcome message. For M3U: paste the full M3U link. Save.' },
      { title: 'Configure the EPG', body: 'IPTVX auto-detects the XMLTV EPG bundled with your iptv subscription. If it doesn\'t appear, Settings → EPG → paste the XMLTV URL we\'ll send you on request.' },
      { title: 'Fine-tune for 4K', body: 'Settings → Player → set "Preferred Video Codec" to HEVC and "Buffer" to 5s for the smoothest 4K sport playback on Apple TV 4K.' },
    ],
    tips: ['IPTVX is one of the few Apple TV IPTV apps with a proper "Recent Channels" row on the home screen — makes flipping between BBC One HD and Sky Sports Main Event a single click.'],
  },
];

const faqs = [
  {
    q: 'Which is the best Apple TV IPTV app in 2026?',
    a: 'For most UK viewers starting an iptv trial, Smarters Player Lite is the best Apple TV IPTV app — it\'s completely free on the tvOS App Store and logs in with a single Xtream Codes username and password. If you want a more polished interface with poster art and AirPlay 2, iPlayTV (£5.99 one-off) is our top paid pick. Power users who juggle multiple iptv subscriptions should install GSE Smart IPTV for its multi-decoder and multi-EPG support.',
  },
  {
    q: 'Do I need to sideload apps on Apple TV?',
    a: 'No — Apple TV does not allow sideloading. Every app in this guide installs directly from the tvOS App Store with a single click, which is one of the biggest advantages of running IPTV on Apple TV over Fire Stick (where several apps have to be sideloaded via Downloader). Your iptv uk trial credentials work the same way — Xtream Codes username, password and server URL — no matter which of the five apps you pick.',
  },
  {
    q: 'Will these apps work on Apple TV HD (4th gen)?',
    a: 'Yes — every app in this guide runs on Apple TV HD (4th gen, released 2015) and every Apple TV 4K generation. The Apple TV HD tops out at 1080p, so you won\'t see the benefit of 4K streams — but for standard UK channels, films and sports at 1080p the experience is identical. For 4K HDR, Dolby Vision and 50Hz sport, upgrade to any Apple TV 4K.',
  },
  {
    q: 'Can I use the same iptv subscription on Apple TV and my Fire Stick or phone?',
    a: `Yes. One ${site.name} iptv subscription includes the same Xtream Codes credentials for every device you own — Apple TV, Fire Stick, Smart TV, iPhone, Android tablet. Just enter the same username, password and server URL in each app. See our Fire Stick and Mobile & Tablet installation guides for those devices.`,
  },
  {
    q: 'Does AirPlay work with these apps?',
    a: 'iPlayTV, IPTVX and GSE Smart IPTV all support AirPlay 2 — you can beam a live UK channel from your iPhone straight to the Apple TV, or from Apple TV to a HomePod for whole-room audio on the football. Smarters Player Lite and Expert have basic AirPlay support for audio only. Every Apple TV in the house sharing one iptv subscription is fully supported.',
  },
  {
    q: 'Is IPTV on Apple TV safe and legal in the UK?',
    a: `Installing the apps in this guide is 100% legal — Smarters Player Lite, IPTV Smarters Player Expert, iPlayTV, GSE Smart IPTV and IPTVX are all legitimate players sold on the official Apple tvOS App Store, so they've passed Apple's app review. What you watch through them depends on your iptv subscription. Every ${site.name} iptv trial ships from licensed servers with a full UK support team on WhatsApp.`,
  },
  {
    q: 'How long does the Apple TV IPTV setup take?',
    a: `Under 3 minutes end-to-end for Smarters Player Lite — that's the fastest path in this guide because Apple TV skips the sideload step entirely. Search the App Store (30s), install with Apple ID (30s), Add New User → Xtream Codes API (1 min) and paste the login we sent you. Every ${site.name} iptv uk trial customer with an Apple TV follows this exact flow on their first day.`,
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.url}/` },
        { '@type': 'ListItem', position: 2, name: 'Installation Guides', item: `${site.url}/installation-guides/` },
        { '@type': 'ListItem', position: 3, name: 'Apple TV', item: canonical },
      ],
    },
    {
      '@type': 'Article',
      headline: 'How to install IPTV on Apple TV — 5 best tvOS apps ranked (2026)',
      description: 'The complete Apple TV IPTV setup guide for Apple TV HD and every Apple TV 4K generation. Compares Smarters Player Lite, IPTV Smarters Player Expert, iPlayTV, GSE Smart IPTV and IPTVX — all working with your iptv uk trial.',
      image: ogImage,
      author: { '@type': 'Organization', name: `${site.name} Editorial`, url: site.url },
      publisher: {
        '@type': 'Organization',
        name: site.name,
        url: site.url,
        logo: { '@type': 'ImageObject', url: `${site.url}/og-image.svg` },
      },
      datePublished: '2026-07-20',
      dateModified: '2026-07-20',
      mainEntityOfPage: canonical,
      articleSection: 'IPTV Installation Guides',
      keywords: 'iptv trial, iptv uk trial, iptv subscriptions, iptv subscription, iptv service, apple tv iptv, apple tv 4k iptv, smarters player lite, iplaytv, gse smart iptv, iptvx',
    },
    {
      '@type': 'HowTo',
      name: 'How to install IPTV on Apple TV HD and Apple TV 4K',
      totalTime: 'PT3M',
      step: apps.flatMap((app) => app.steps.map((s, i) => ({
        '@type': 'HowToStep',
        name: `${app.name} — ${s.title}`,
        text: s.body,
        position: i + 1,
      }))),
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};

const relatedGuides = [
  { slug: 'firestick', label: 'Set up IPTV on Fire Stick', device: 'Fire Stick' },
  { slug: 'smart-tv', label: 'Set up IPTV on Smart TV', device: 'Smart TV' },
  { slug: 'mobile-tablet', label: 'Set up IPTV on Mobile & Tablet', device: 'Mobile' },
  { slug: 'nvidia-shield', label: 'Set up IPTV on Nvidia Shield', device: 'Nvidia Shield' },
];
---
<BaseLayout
  title={`Apple TV IPTV Setup: 5 Best tvOS Apps (2026) | ${site.name}`}
  description="Install IPTV on Apple TV HD or any Apple TV 4K in under 3 minutes. Step-by-step guides for Smarters Player Lite, IPTV Smarters Player Expert, iPlayTV, GSE Smart IPTV and IPTVX — all direct from the tvOS App Store, all working with your iptv uk trial."
  canonical={canonical}
  ogImage={ogImage}
  includeSchema={false}
>
  <Header />
  <main id="main">
    <!-- Hero -->
    <section class="relative overflow-hidden border-b border-border-subtle">
      <div class="pointer-events-none absolute inset-0 -z-10 opacity-70">
        <div class="absolute -top-40 left-1/2 h-[560px] w-[900px] -translate-x-1/2 rounded-full bg-grad-brand-soft blur-3xl"></div>
      </div>
      <div class="container-x pt-14 pb-12 md:pt-20 md:pb-16 max-w-3xl">
        <nav aria-label="Breadcrumb" class="text-xs uppercase tracking-widest text-text-muted">
          <a href="/" class="hover:text-brand-light">Home</a>
          <span class="mx-2 text-border-subtle">/</span>
          <a href="/installation-guides/" class="hover:text-brand-light">Installation Guides</a>
          <span class="mx-2 text-border-subtle">/</span>
          <span class="text-text-primary">Apple TV</span>
        </nav>

        <div class="mt-6 flex items-center gap-4">
          <span class="flex h-14 w-14 items-center justify-center rounded-xl border border-brand/20 bg-brand/10 text-brand-light">
            <Icon name="zap" size={28} />
          </span>
          <div>
            <p class="text-[11px] font-semibold uppercase tracking-widest text-text-muted">
              3 min read · Step-by-step
            </p>
            <span class="eyebrow mt-1 block">Apple TV HD &amp; 4K setup</span>
          </div>
        </div>

        <h1 class="mt-6 font-display text-3xl md:text-5xl font-bold tracking-tight text-text-primary">
          Apple TV IPTV — 5 best tvOS apps for Apple TV HD &amp; 4K (2026)
        </h1>
        <p class="mt-5 text-lg text-text-muted leading-relaxed">
          Apple TV is the fastest way to run <strong>IPTV</strong> in the UK — no sideloading, no
          Developer Options, no Downloader. Every app in this guide installs with a single click
          from the official tvOS App Store, and every one of them logs in with the exact same
          Xtream Codes credentials that come with your
          <a href="/#pricing" class="text-brand-light underline underline-offset-4 decoration-brand/40 hover:decoration-brand-light">£{site.price} IPTV UK trial</a>.
          Works on Apple TV HD (4th gen, 2015) and every Apple TV 4K generation.
        </p>

        <p class="mt-6 inline-flex items-center gap-2 text-xs uppercase tracking-widest text-text-muted">
          <span class="h-1.5 w-1.5 rounded-full bg-brand-light"></span>
          Published {publishedFmt} · Updated {updatedFmt}
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href={waLink(`Hi, I'd like to start my £${site.price} IPTV trial on my Apple TV.`)} class="btn-primary" target="_blank" rel="nofollow noopener noreferrer">
            Start £{site.price} IPTV trial
          </a>
          <a href="#apps" class="btn-secondary">Choose an app</a>
        </div>

        <figure class="mt-10 overflow-hidden rounded-2xl border border-border-subtle bg-elevated/60">
          <img
            src="https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/Apple_TV_IPTV_guide_2026_202607210427.jpeg"
            alt="Apple TV IPTV setup — Smarters Player Lite, iPlayTV, GSE Smart IPTV and IPTVX on Apple TV 4K"
            width="1200"
            height="630"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="w-full h-auto"
            onerror="this.src='/installation-guides/smart-tv-hero.svg'"
          />
        </figure>
      </div>
    </section>

    <!-- Body -->
    <section class="container-x py-14 md:py-20 max-w-3xl is-visible" data-reveal="fade">
      <article class="legal-prose">
        <p>
          Every <strong>Apple TV</strong> sold since 2015 can run <strong>IPTV</strong> in under
          3 minutes — the biggest advantage over Fire Stick is that Apple TV skips the sideload
          step entirely, because every app in this guide is on the official tvOS App Store. This
          guide covers the five apps we actively support, ranked by how quickly you can go from
          "just unboxed the Apple TV" to watching UK channels, sports, films and series on your
          first <strong>iptv trial</strong>. Every app works with the same Xtream Codes credentials
          or M3U playlist that comes with your <strong>iptv subscription</strong> — no re-buying,
          no per-device fee.
        </p>

        <p>Short on time? The three options that cover 95% of Apple TV setups:</p>
        <ul>
          <li><a href="#smarters-lite"><strong>Smarters Player Lite</strong></a> — 100% free, Xtream Codes login, the classic Apple TV IPTV app</li>
          <li><a href="#iplaytv"><strong>iPlayTV</strong></a> — £5.99 one-off, Netflix-style interface and AirPlay 2</li>
          <li><a href="#iptvx"><strong>IPTVX</strong></a> — ≈£4.99 one-off, the most Apple-like interface on tvOS</li>
        </ul>
      </article>

      <!-- Paid apps callout -->
      <div class="mt-10 rounded-2xl border border-brand/25 bg-brand/5 p-5 md:p-6">
        <div class="flex items-start gap-3">
          <span class="mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand/15 text-brand-light">
            <Icon name="sparkles" size={16} />
          </span>
          <div class="min-w-0">
            <p class="font-semibold text-text-primary">About the paid apps</p>
            <p class="mt-2 text-sm text-text-muted leading-relaxed">
              IPTV Smarters Player Expert, iPlayTV, GSE Smart IPTV Pro and IPTVX are all
              <span class="text-brand-light font-medium">one-off App Store purchases</span> — you
              pay Apple once and the app is yours forever on your Apple ID. No monthly fees, no
              in-app subscriptions. Tap any app card for exact steps.
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              <a href="https://apps.apple.com/us/app/iptv-smarters-player-expert/id1641944027" target="_blank" rel="nofollow noopener noreferrer" class="btn-secondary text-xs">Smarters Player Expert ↗</a>
              <a href="https://apps.apple.com/gb/app/iplaytv/id1072226801" target="_blank" rel="nofollow noopener noreferrer" class="btn-secondary text-xs">iPlayTV ↗</a>
              <a href="https://apps.apple.com/gb/search?term=gse+smart+iptv" target="_blank" rel="nofollow noopener noreferrer" class="btn-secondary text-xs">GSE Smart IPTV ↗</a>
              <a href="https://apps.apple.com/gb/search?term=iptvx" target="_blank" rel="nofollow noopener noreferrer" class="btn-secondary text-xs">IPTVX ↗</a>
            </div>
          </div>
        </div>
      </div>

      <!-- App selector list -->
      <h2 id="apps" class="mt-16 font-display text-2xl md:text-3xl font-bold text-text-primary scroll-mt-24">
        Choose an app
      </h2>
      <p class="mt-3 text-text-muted">
        Tap any app to jump to its full step-by-step Apple TV IPTV setup.
      </p>
      <ul class="mt-6 space-y-3">
        {apps.map((app) => (
          <li>
            <a
              href={`#${app.slug}`}
              class="card group flex items-center gap-4 p-4 transition hover:border-brand/50"
            >
              <img
                src={app.logo}
                alt={`${app.name} logo`}
                width="48"
                height="48"
                loading="lazy"
                decoding="async"
                class="h-12 w-12 shrink-0 rounded-xl border border-border-subtle bg-elevated"
                onerror="this.src='/og-image.svg'"
              />
              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="text-base font-semibold text-text-primary group-hover:text-brand-light">{app.name}</span>
                  {app.tag === 'free' ? (
                    <span class="rounded-full border border-emerald-400/40 bg-emerald-400/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-emerald-300">Free</span>
                  ) : (
                    <span class="rounded-full border border-amber-400/40 bg-amber-400/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-amber-300">Paid app</span>
                  )}
                  {app.price && (
                    <span class="rounded-full border border-border-subtle bg-elevated/60 px-2 py-0.5 text-[10px] text-text-muted">
                      {app.price}
                    </span>
                  )}
                </div>
                <p class="mt-1 text-xs text-text-muted line-clamp-1">{app.supported}</p>
              </div>
              <span class="text-brand-light shrink-0"><Icon name="chevron-right" size={18} /></span>
            </a>
          </li>
        ))}
      </ul>

      <!-- Per-app deep cards -->
      <div class="mt-14 space-y-14">
        {apps.map((app, idx) => (
          <article id={app.slug} class="card p-6 md:p-8 scroll-mt-24">
            <div class="flex items-start gap-4">
              <img
                src={app.logo}
                alt={`${app.name} logo`}
                width="72"
                height="72"
                loading="lazy"
                decoding="async"
                class="h-16 w-16 md:h-[72px] md:w-[72px] shrink-0 rounded-2xl border border-border-subtle bg-elevated"
                onerror="this.src='/og-image.svg'"
              />
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <p class="text-[11px] font-semibold uppercase tracking-widest text-brand-light">
                    App {idx + 1} of {apps.length}
                  </p>
                  {app.tag === 'free' ? (
                    <span class="rounded-full border border-emerald-400/40 bg-emerald-400/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-emerald-300">Free</span>
                  ) : (
                    <span class="rounded-full border border-amber-400/40 bg-amber-400/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-amber-300">Paid app</span>
                  )}
                </div>
                <h2 class="mt-1 font-display text-2xl md:text-[28px] font-bold text-text-primary">
                  {app.name}
                </h2>
                {app.price && (
                  <p class="mt-1 text-sm text-text-muted">{app.price}</p>
                )}
              </div>
            </div>

            <p class="mt-6 text-text-muted leading-relaxed">{app.copy}</p>

            <div class="mt-6 grid gap-4 sm:grid-cols-2">
              <div class="rounded-xl border border-border-subtle bg-elevated/50 p-4">
                <p class="text-[11px] font-semibold uppercase tracking-widest text-text-muted">Log in via</p>
                <p class="mt-1 text-sm text-text-primary">{app.login}</p>
              </div>
              <div class="rounded-xl border border-border-subtle bg-elevated/50 p-4">
                <p class="text-[11px] font-semibold uppercase tracking-widest text-text-muted">Supported devices</p>
                <p class="mt-1 text-sm text-text-primary">{app.supported}</p>
              </div>
            </div>

            <h3 class="mt-8 font-display text-lg md:text-xl font-semibold text-text-primary">Step-by-step</h3>
            <ol class="mt-4 space-y-4">
              {app.steps.map((s, i) => (
                <li class="flex gap-4">
                  <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-grad-brand text-xs font-bold text-white shadow-glow">
                    {i + 1}
                  </span>
                  <div class="min-w-0">
                    <p class="text-sm md:text-base font-semibold text-text-primary">{s.title}</p>
                    <p class="mt-1 text-sm text-text-muted leading-relaxed">{s.body}</p>
                  </div>
                </li>
              ))}
            </ol>

            {app.tips && app.tips.length > 0 && (
              <div class="mt-6 rounded-xl border border-brand/25 bg-brand/5 p-4">
                <p class="text-[11px] font-semibold uppercase tracking-widest text-brand-light">Tip</p>
                <ul class="mt-2 space-y-1.5 text-sm text-text-muted">
                  {app.tips.map((t) => (
                    <li class="flex gap-2">
                      <span class="mt-1 inline-flex h-4 w-4 shrink-0 items-center justify-center text-brand-light">
                        <Icon name="check" size={14} />
                      </span>
                      <span set:html={t}></span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <div class="mt-6 flex flex-wrap gap-3">
              <a
                href={waLink(`Hi, I'd like to set up ${app.name} on my Apple TV with your £${site.price} IPTV trial.`)}
                class="btn-primary"
                target="_blank"
                rel="nofollow noopener noreferrer"
              >
                Activate my {app.name}
              </a>
              {app.activateUrl && (
                <a href={app.activateUrl} target="_blank" rel="nofollow noopener noreferrer" class="btn-secondary">
                  App Store ↗
                </a>
              )}
            </div>
          </article>
        ))}
      </div>

      <!-- Comparison -->
      <h2 id="comparison" class="mt-16 font-display text-2xl md:text-3xl font-bold text-text-primary scroll-mt-24">
        Apple TV IPTV apps — side-by-side
      </h2>
      <p class="mt-3 text-text-muted">All five apps at a glance.</p>
      <div class="mt-6 overflow-x-auto rounded-2xl border border-border-subtle">
        <table class="w-full min-w-[720px] text-left text-sm">
          <thead class="bg-elevated/70 text-text-primary">
            <tr>
              <th class="p-3 font-semibold">App</th>
              <th class="p-3 font-semibold">Type</th>
              <th class="p-3 font-semibold">Install</th>
              <th class="p-3 font-semibold">Login</th>
              <th class="p-3 font-semibold">Price</th>
            </tr>
          </thead>
          <tbody class="text-text-muted">
            {apps.map((app) => (
              <tr class="border-t border-border-subtle/60">
                <td class="p-3 text-text-primary font-medium">{app.name}</td>
                <td class="p-3">{app.tag === 'free' ? 'Free' : 'Paid'}</td>
                <td class="p-3">tvOS App Store</td>
                <td class="p-3">{app.login.split('(')[0].split('·')[0].trim()}</td>
                <td class="p-3">{app.tag === 'free' ? 'Free' : (app.price?.split('·')[0]?.trim() ?? '—')}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Buyer's guide -->
      <article class="legal-prose mt-16">
        <h2>Which Apple TV IPTV app should I actually use?</h2>
        <p>
          If you want the shortest possible answer: install <strong>Smarters Player Lite</strong>
          first because it's free and it's what every UK IPTV provider tests against. If the
          interface feels basic, buy <strong>iPlayTV</strong> next — the £5.99 one-off gets you a
          Netflix-style poster grid, AirPlay 2 and catch-up TV support. If you're a design
          purist, <strong>IPTVX</strong> is the most Apple-like player on tvOS. Power users who
          run multiple iptv subscriptions or need custom stream headers should install
          <strong>GSE Smart IPTV</strong>.
        </p>

        <h3>Apple TV HD (4th gen) owners</h3>
        <p>
          Stick to the lightweight apps: <strong>Smarters Player Lite</strong> and
          <strong>IPTV Smarters Player Expert</strong> run smoothest on the older A8 chip. Skip
          any 4K streams in your iptv subscription — the Apple TV HD tops out at 1080p and can
          stutter on very high-bitrate 4K feeds. All five apps still install and work perfectly
          for standard HD content.
        </p>

        <h3>Apple TV 4K (1st–3rd gen) owners</h3>
        <p>
          Any Apple TV 4K is our top recommendation for a serious <strong>iptv service</strong> —
          enough memory to keep two IPTV apps installed side-by-side (Smarters Player Lite +
          iPlayTV is our favourite pairing) and enough grunt for 4K HEVC HDR without frame drops.
          The 3rd-gen Apple TV 4K (2022, A15 Bionic) is genuinely the fastest IPTV box you can
          buy — every app in this guide runs at full 4K HDR and Dolby Vision on it.
        </p>

        <h3>Match Content, Dolby Vision &amp; AirPlay 2</h3>
        <p>
          Turn on "Match Content" in Apple TV → Settings → Video and Audio → Match Content →
          enable both "Match Dynamic Range" and "Match Frame Rate". This makes the Apple TV
          switch automatically between SDR, HDR, Dolby Vision and 50Hz depending on the channel
          — the difference on UK sport at 50fps is night and day. Enable AirPlay 2 in iPlayTV,
          IPTVX or GSE to beam channels to a HomePod or a second Apple TV in another room.
        </p>

        <h2>Try our IPTV UK trial on any of these apps</h2>
        <p>
          Every app on this page works with our <a href="/#pricing">30-day £{site.price} IPTV trial</a> —
          same Xtream Codes credentials or M3U playlist, same UK support on WhatsApp. One set of
          <strong>iptv subscriptions</strong> credentials works across Apple TV, Fire Stick, Smart
          TV, phone and tablet — no per-device fee. If you install one of the paid Apple TV apps,
          your one-off App Store purchase is completely separate from your <strong>iptv subscription</strong>
          with us, so you can genuinely test the app before committing.
        </p>

        <h2>Frequently asked questions</h2>
      </article>

      <!-- FAQ -->
      <div class="mt-8 space-y-3">
        {faqs.map((f) => (
          <details class="group rounded-2xl border border-border-subtle bg-elevated/60 p-5 md:p-6 open:border-brand/40">
            <summary class="flex cursor-pointer list-none items-start justify-between gap-4">
              <h3 class="text-base md:text-lg font-semibold text-text-primary">{f.q}</h3>
              <span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-border-subtle text-brand-light transition group-open:rotate-180">
                <Icon name="chevron-down" size={14} />
              </span>
            </summary>
            <p class="mt-3 text-text-muted leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>

      <!-- Help card -->
      <aside class="mt-14 card p-6 md:p-8">
        <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-text-muted">Stuck?</p>
        <h2 class="mt-2 font-display text-2xl font-semibold text-text-primary">We'll set it up for you</h2>
        <p class="mt-3 text-text-muted">
          Every {site.name} subscription includes free hands-on Apple TV setup support. Message us
          on WhatsApp with your Apple TV model (HD or 4K generation) and we'll walk you through it,
          or push your playlist across remotely.
        </p>
        <div class="mt-6">
          <a href={waLink(`Hi, I need help setting up IPTV on my Apple TV.`)} class="btn-primary" target="_blank" rel="nofollow noopener noreferrer">
            <Icon name="whatsapp" size={16} class="mr-2" />
            Chat with UK support
          </a>
        </div>
      </aside>

      <!-- Related guides -->
      <aside class="mt-14">
        <h2 class="font-display text-xl md:text-2xl font-semibold text-text-primary">Other installation guides</h2>
        <ul class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3">
          {relatedGuides.map((g) => (
            <li>
              <a
                href={`/installation-guides/${g.slug}/`}
                class="card group flex items-center justify-between gap-3 p-4 transition hover:border-brand/50"
              >
                <span class="text-sm md:text-base font-medium text-text-primary group-hover:text-brand-light">{g.label}</span>
                <span class="text-brand-light"><Icon name="arrow" size={16} /></span>
              </a>
            </li>
          ))}
        </ul>
      </aside>
    </section>

    <FinalCta />
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</BaseLayout>
