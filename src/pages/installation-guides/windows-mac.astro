---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Icon from '../../components/Icon.astro';
import FinalCta from '../../components/FinalCta.astro';
import { site, waLink } from '../../data/site';

const canonical = `${site.url}/installation-guides/windows-mac/`;
const ogImage = 'https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/Desktop_IPTV_guide_graphic_202607210426.jpeg';
const publishedFmt = '20 July 2026';
const updatedFmt = '20 July 2026';

type App = {
  slug: string;
  name: string;
  tag: 'free' | 'paid';
  price?: string;
  logo: string;
  login: string;
  supported: string;
  activateUrl?: string;
  copy: string;
  steps: { title: string; body: string }[];
  tips?: string[];
};

const apps: App[] = [
  {
    slug: 'smarters',
    name: 'IPTV Smarters Pro (Desktop)',
    tag: 'free',
    logo: 'https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/iptv-smarters.webp',
    login: 'Xtream Codes API (username + password + server URL)',
    supported: 'Windows 10 · Windows 11 · macOS 11+ (Intel & Apple Silicon)',
    copy: `IPTV Smarters Pro is the fastest way to run your ${site.name} iptv trial on a Windows PC, MacBook or iMac. The desktop build logs in with the exact same Xtream Codes credentials as the Fire Stick and mobile versions, so a single iptv subscription covers your laptop and your TV with no extra config. Runs natively on Apple Silicon (M1 / M2 / M3) — no Rosetta needed.`,
    steps: [
      { title: 'Download the desktop installer', body: 'From your browser go to iptvsmarters.com/downloads and grab the Windows .exe or macOS .dmg for your system. Both are free.' },
      { title: 'Install and open', body: 'On Windows double-click the .exe and follow the wizard. On macOS drag the app icon into Applications, then right-click → Open the first time so Gatekeeper allows it.' },
      { title: 'Choose Login with Xtream Codes API', body: 'Add New User → Login with Xtream Codes API — the fastest, most reliable login method for any iptv service.' },
      { title: 'Paste the details we sent you', body: 'Give it a nickname (e.g. "Laptop"), then paste the username, password and server URL from your welcome message. Save.' },
      { title: 'Start streaming', body: 'The app loads your full channel list, EPG, VOD and series. Full-screen with F11 (Windows) or ⌃⌘F (macOS).' },
    ],
    tips: ['On Apple Silicon Macs, the native ARM build is roughly 30% smoother than the Intel version on 4K channels — make sure you download the "Apple Silicon" .dmg, not the Intel one.'],
  },
  {
    slug: 'hot',
    name: 'Hot Player / Hot IPTV',
    tag: 'paid',
    price: '€5.99/yr · €14.99 lifetime · 30-day free trial',
    logo: 'https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/hot-player.webp',
    login: 'M3U playlist URL (uploaded at hotplayer.app/upload)',
    supported: 'Windows 10 · Windows 11 · macOS 11+ · iOS · Android · Smart TV · Fire TV',
    activateUrl: 'https://hotplayer.app/activation',
    copy: `Hot Player has the longest free trial of any Windows or Mac IPTV app — a full 30 days — which makes it the perfect partner for a monthly iptv uk trial. It's the same Hot Player you'd install on a Fire Stick or Smart TV, and your playlist stays synchronised across every device once you upload it. €14.99 lifetime is one of the best-value one-off IPTV player prices on the market.`,
    steps: [
      { title: 'Download Hot Player for desktop', body: 'From hotplayer.app go to Downloads and pick the Windows installer or macOS .dmg. Install as normal.' },
      { title: 'Open the app and read your device ID', body: 'On first launch Hot Player shows a device ID / MAC. Take a screenshot.' },
      { title: 'Send us the device ID on WhatsApp', body: 'Message us the ID along with your order name. We generate a personal M3U playlist URL for your iptv subscription.' },
      { title: 'Upload the playlist on hotplayer.app/upload', body: 'Open hotplayer.app/upload in your browser, enter the device ID and paste the M3U URL we sent you. Save.' },
      { title: 'Restart Hot Player', body: 'Close and reopen the desktop app — your channels load. 30 days free, then €5.99/yr or €14.99 lifetime on hotplayer.app/activation.' },
    ],
    tips: ['Hot Player syncs one playlist across every device on the same account — set it up once on desktop and it will show up automatically on your Fire Stick and phone.'],
  },
  {
    slug: 'ibo',
    name: 'IBO Player Pro (Windows)',
    tag: 'paid',
    price: '≈ €8 lifetime · 7-day free trial',
    logo: 'https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/ibo-player.webp',
    login: 'Device Key + MAC (activated on iboproapp.com)',
    supported: 'Windows 10 · Windows 11 · Fire TV · Smart TV · Apple TV · iOS · Android',
    activateUrl: 'https://iboproapp.com',
    copy: `IBO Player Pro brings its Netflix-style interface to Windows — a proper 10-foot lean-back UI you can drive with a keyboard or a Bluetooth remote when you connect the PC to a TV. 7-day free trial baked in and a one-off ~€8 unlocks it for life on that specific machine. Currently Windows-only on desktop (macOS build is on their roadmap).`,
    steps: [
      { title: 'Download the Windows installer', body: 'Visit iboproapp.com/downloads and get the Windows .exe. Install as normal.' },
      { title: 'Open the app and read your Device Key + MAC', body: 'On first launch you\'ll see a Device Key AND a MAC address. Copy both — you need them.' },
      { title: 'Send us both codes on WhatsApp', body: 'We attach your playlist within about 10 minutes and confirm when it\'s live.' },
      { title: 'Reload and enjoy the 7-day trial', body: 'Restart IBO Player — channels, VOD and series appear. Enjoy 7 days free.' },
      { title: 'Activate for life on iboproapp.com', body: 'When the trial ends, visit iboproapp.com, enter the same Device Key + MAC and pay the one-off lifetime fee.' },
    ],
    tips: ['IBO Player Pro doesn\'t ship a native macOS build yet. Mac users should install IPTV Smarters Pro (native Apple Silicon) or VLC instead — the same iptv subscription credentials work on both.'],
  },
  {
    slug: 'vlc',
    name: 'VLC Media Player',
    tag: 'free',
    logo: 'https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/vlc.webp',
    login: 'M3U playlist URL',
    supported: 'Windows 10 · Windows 11 · macOS 10.11+ · Linux',
    activateUrl: 'https://www.videolan.org/vlc/',
    copy: `VLC is the free, universally-installed media player that quietly happens to be a great IPTV client on Windows and Mac. Paste the M3U URL we send you and VLC opens the whole channel list as a playlist. No EPG, no VOD polish — just a rock-solid free option for anyone who doesn't want to install another app to test their iptv trial on a laptop.`,
    steps: [
      { title: 'Install VLC (if you don\'t have it)', body: 'Get it free from videolan.org/vlc. Available for Windows and macOS — Apple Silicon build included.' },
      { title: 'Grab your M3U URL from WhatsApp', body: 'We send you a personal M3U playlist URL as part of every iptv subscription. Copy it.' },
      { title: 'Open the URL in VLC', body: 'Windows: Media → Open Network Stream → paste the URL → Play. macOS: File → Open Network → paste the URL → Open.' },
      { title: 'Save it as a playlist', body: 'While the channel list is loaded, Media / File → Save Playlist to File → save an .m3u somewhere memorable so you can reopen it in one click.' },
    ],
    tips: ['VLC has no EPG — for a proper TV Guide use IPTV Smarters Pro or Hot Player instead. Keep VLC as your emergency backup player.'],
  },
  {
    slug: 'kodi',
    name: 'Kodi + PVR IPTV Simple Client',
    tag: 'free',
    logo: 'https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/kodi.webp',
    login: 'M3U playlist URL (loaded into PVR IPTV Simple Client)',
    supported: 'Windows 10 · Windows 11 · macOS 11+ · Linux · Fire TV · Android',
    activateUrl: 'https://kodi.tv',
    copy: `Kodi is the power-user's Windows / Mac IPTV app. Free, open source, brilliant EPG once configured, and it lets you record live TV to your hard drive. The one-off setup is longer than IPTV Smarters Pro — you enable the PVR IPTV Simple Client add-on and point it at your M3U URL — but for anyone building a proper home-cinema PC it's the best free iptv service front-end on desktop.`,
    steps: [
      { title: 'Install Kodi', body: 'Free from kodi.tv — pick the Windows .exe or macOS .dmg. Open it once you\'ve installed.' },
      { title: 'Enable PVR IPTV Simple Client', body: 'Settings → Add-ons → My add-ons → PVR clients → PVR IPTV Simple Client → Enable.' },
      { title: 'Point it at your M3U URL', body: 'Same screen → Configure → General → M3U Play List URL → paste the URL from your welcome message. OK.' },
      { title: 'Restart Kodi', body: 'Quit and reopen Kodi. The TV section fills with your channels and (a few minutes later) the EPG.' },
      { title: 'Optional: enable catch-up + recording', body: 'PVR IPTV Simple Client → Catchup — enable if your iptv subscription includes it. Then Settings → PVR & Live TV → set a recordings folder.' },
    ],
  },
];

const faqs = [
  {
    q: 'Which is the best IPTV app for Windows and Mac in 2026?',
    a: 'For 95% of laptop users on their first iptv trial, IPTV Smarters Pro (Desktop) is the best pick — free, native Apple Silicon build for Mac, one-step Xtream Codes login. If you want a longer free trial before paying anything, Hot Player gives you 30 days. If you don\'t want to install a new app at all, VLC plays your M3U playlist with zero setup.',
  },
  {
    q: 'Does IPTV work on Apple Silicon (M1, M2, M3, M4) Macs?',
    a: 'Yes — IPTV Smarters Pro, VLC and Kodi all ship native Apple Silicon builds and run smoothly on any M1 / M2 / M3 / M4 MacBook, MacBook Pro, MacBook Air, iMac or Mac mini. Hot Player runs via Rosetta 2 on Intel and Apple Silicon — smooth at 1080p, occasional frame drops at 4K on the base M1. IBO Player Pro is currently Windows-only on desktop.',
  },
  {
    q: 'Do I need a paid app to watch IPTV on my laptop?',
    a: 'No. IPTV Smarters Pro (Desktop), VLC and Kodi are all completely free. Hot Player and IBO Player Pro come with free trials (30 days and 7 days respectively) — install one, load your playlist and test it. When the trial ends you activate the app on its own site: hotplayer.app/activation or iboproapp.com. Payment for those apps is completely separate from your iptv subscription with us.',
  },
  {
    q: 'Can I use the same iptv subscription on my laptop and my TV?',
    a: `Yes — one ${site.name} iptv subscription includes the same Xtream Codes credentials (or M3U URL) for every device you own. Windows laptop, MacBook, Fire Stick, Smart TV, iPhone, Android tablet — same login everywhere, no per-device fee. See our other installation guides for TV and mobile setups.`,
  },
  {
    q: 'How do I install IPTV on a work laptop with restricted admin rights?',
    a: 'The easiest option is VLC — many corporate machines already have it installed, and even if they don\'t, VLC installs without admin rights on most Windows setups. Just paste your M3U URL via Media → Open Network Stream. Kodi\'s portable build also runs without admin on Windows. IPTV Smarters Pro and Hot Player both need admin rights on Windows.',
  },
  {
    q: 'Do these desktop apps support 4K IPTV?',
    a: 'Yes. IPTV Smarters Pro, Hot Player, IBO Player Pro, VLC and Kodi all support 4K HEVC / H.265 playback on any modern Windows PC or Mac with a decent internet connection (25 Mbps+). For the smoothest 4K experience use a wired Ethernet connection rather than Wi-Fi — the difference on channels above 15 Mbps is significant.',
  },
  {
    q: 'Is IPTV safe to install on my Windows PC or Mac?',
    a: 'The apps in this guide are all legitimate players downloaded from their own official sites (iptvsmarters.com, hotplayer.app, iboproapp.com, videolan.org, kodi.tv). None of them contain malware. What you stream through them depends on your iptv subscription — every ' + site.name + ' iptv trial ships from licensed servers with a full UK support team on WhatsApp.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.url}/` },
        { '@type': 'ListItem', position: 2, name: 'Installation Guides', item: `${site.url}/installation-guides/` },
        { '@type': 'ListItem', position: 3, name: 'Windows & Mac', item: canonical },
      ],
    },
    {
      '@type': 'Article',
      headline: 'How to install IPTV on Windows and Mac — 5 best desktop apps ranked',
      description: 'The complete Windows and macOS IPTV setup guide. Compares IPTV Smarters Pro (Desktop), Hot Player, IBO Player Pro, VLC and Kodi — all compatible with your iptv uk trial on Windows 10/11 and Apple Silicon Macs.',
      image: ogImage,
      author: { '@type': 'Organization', name: `${site.name} Editorial`, url: site.url },
      publisher: {
        '@type': 'Organization',
        name: site.name,
        url: site.url,
        logo: { '@type': 'ImageObject', url: `${site.url}/og-image.svg` },
      },
      datePublished: '2026-07-20',
      dateModified: '2026-07-20',
      mainEntityOfPage: canonical,
      articleSection: 'IPTV Installation Guides',
      keywords: 'iptv trial, iptv uk trial, iptv subscriptions, iptv subscription, iptv service, windows iptv, mac iptv, macbook iptv, iptv smarters pro, hot player, ibo player pro, vlc iptv, kodi iptv',
    },
    {
      '@type': 'HowTo',
      name: 'How to install IPTV on Windows and Mac',
      totalTime: 'PT5M',
      step: apps.flatMap((app) => app.steps.map((s, i) => ({
        '@type': 'HowToStep',
        name: `${app.name} — ${s.title}`,
        text: s.body,
        position: i + 1,
      }))),
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};

const relatedGuides = [
  { slug: 'smart-tv', label: 'Set up IPTV on Smart TV', device: 'Smart TV' },
  { slug: 'firestick', label: 'Set up IPTV on Fire Stick & Cube', device: 'Fire Stick' },
  { slug: 'mobile-tablet', label: 'Set up IPTV on Mobile & Tablet', device: 'Mobile' },
  { slug: 'apple-tv', label: 'Set up IPTV on Apple TV', device: 'Apple TV' },
];
---
<BaseLayout
  title={`Windows & Mac IPTV setup — 5 best desktop apps (2026) | ${site.name}`}
  description="Install IPTV on any Windows 10/11 PC or Mac (Intel or Apple Silicon) in under 5 minutes. Step-by-step guides for IPTV Smarters Pro, Hot Player, IBO Player Pro, VLC and Kodi — all working with your iptv uk trial."
  canonical={canonical}
  ogImage={ogImage}
  includeSchema={false}
>
  <Header />
  <main id="main">
    <!-- Hero -->
    <section class="relative overflow-hidden border-b border-border-subtle">
      <div class="pointer-events-none absolute inset-0 -z-10 opacity-70">
        <div class="absolute -top-40 left-1/2 h-[560px] w-[900px] -translate-x-1/2 rounded-full bg-grad-brand-soft blur-3xl"></div>
      </div>
      <div class="container-x pt-14 pb-12 md:pt-20 md:pb-16 max-w-3xl">
        <nav aria-label="Breadcrumb" class="text-xs uppercase tracking-widest text-text-muted">
          <a href="/" class="hover:text-brand-light">Home</a>
          <span class="mx-2 text-border-subtle">/</span>
          <a href="/installation-guides/" class="hover:text-brand-light">Installation Guides</a>
          <span class="mx-2 text-border-subtle">/</span>
          <span class="text-text-primary">Windows &amp; Mac</span>
        </nav>

        <div class="mt-6 flex items-center gap-4">
          <span class="flex h-14 w-14 items-center justify-center rounded-xl border border-brand/20 bg-brand/10 text-brand-light">
            <Icon name="laptop" size={28} />
          </span>
          <div>
            <p class="text-[11px] font-semibold uppercase tracking-widest text-text-muted">
              5 min read · Step-by-step
            </p>
            <span class="eyebrow mt-1 block">Windows &amp; Mac setup</span>
          </div>
        </div>

        <h1 class="mt-6 font-display text-3xl md:text-5xl font-bold tracking-tight text-text-primary">
          Windows &amp; Mac IPTV — 5 best desktop apps (2026)
        </h1>
        <p class="mt-5 text-lg text-text-muted leading-relaxed">
          Run <strong>IPTV</strong> on any Windows 10/11 PC, Intel Mac or Apple Silicon MacBook in
          under 5 minutes. This guide covers the five desktop apps we support — from the free
          go-to (<strong>IPTV Smarters Pro Desktop</strong>) to the longest free trial on the market
          (<strong>Hot Player</strong>, 30 days), plus <strong>IBO Player Pro</strong>, <strong>VLC</strong>
          and <strong>Kodi</strong> for power users. All work with our
          <a href="/#pricing" class="text-brand-light underline underline-offset-4 decoration-brand/40 hover:decoration-brand-light">£{site.price} IPTV UK trial</a>.
        </p>

        <p class="mt-6 inline-flex items-center gap-2 text-xs uppercase tracking-widest text-text-muted">
          <span class="h-1.5 w-1.5 rounded-full bg-brand-light"></span>
          Published {publishedFmt} · Updated {updatedFmt}
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href={waLink(`Hi, I'd like to start my £${site.price} IPTV trial on my laptop.`)} class="btn-primary" target="_blank" rel="nofollow noopener noreferrer">
            Start £{site.price} IPTV trial
          </a>
          <a href="#apps" class="btn-secondary">Choose an app</a>
        </div>

        <figure class="mt-10 overflow-hidden rounded-2xl border border-border-subtle bg-elevated/60">
          <img
            src="https://pub-a911d0797db04b879a41ba8f0cdf2db6.r2.dev/Desktop_IPTV_guide_graphic_202607210426.jpeg"
            alt="Windows and Mac IPTV setup — IPTV Smarters Pro, Hot Player, IBO Player Pro, VLC and Kodi"
            width="1200"
            height="630"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="w-full h-auto"
            onerror="this.src='/installation-guides/smart-tv-hero.svg'"
          />
        </figure>
      </div>
    </section>

    <!-- Body -->
    <section class="container-x py-14 md:py-20 max-w-3xl is-visible" data-reveal="fade">
      <article class="legal-prose">
        <p>
          Every modern Windows PC, MacBook and iMac in the UK can run <strong>IPTV</strong> natively —
          no extra hardware, no browser plug-ins. This guide walks through the five desktop apps we
          actively support, ranked by how quickly you can go from "opened a fresh laptop" to watching
          UK channels, sports and films on your first <strong>iptv trial</strong>. Every app in this
          list works with the same Xtream Codes credentials (or M3U playlist) that ship with your
          <strong>iptv subscription</strong> — one login covers your laptop, TV, phone and Fire Stick.
        </p>

        <p>Short on time? The three options that cover 95% of desktop setups:</p>
        <ul>
          <li><a href="#smarters"><strong>IPTV Smarters Pro (Desktop)</strong></a> — 100% free, Xtream Codes login, native Apple Silicon build</li>
          <li><a href="#hot"><strong>Hot Player / Hot IPTV</strong></a> — 30-day free trial, best if you're only running a monthly iptv uk trial</li>
          <li><a href="#ibo"><strong>IBO Player Pro</strong></a> — ≈€8 lifetime, 7-day free trial, Windows-only but the most polished paid app</li>
        </ul>
      </article>

      <!-- Paid apps callout -->
      <div class="mt-10 rounded-2xl border border-brand/25 bg-brand/5 p-5 md:p-6">
        <div class="flex items-start gap-3">
          <span class="mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand/15 text-brand-light">
            <Icon name="sparkles" size={16} />
          </span>
          <div class="min-w-0">
            <p class="font-semibold text-text-primary">About the paid apps</p>
            <p class="mt-2 text-sm text-text-muted leading-relaxed">
              Hot Player and IBO Player Pro each come with a <span class="text-brand-light font-medium">free trial</span> — install one, load your playlist and test it properly.
              When the trial ends, you activate (pay for) the app on its <strong>own official site</strong> below. Tap any app card for its exact steps.
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              <a href="https://hotplayer.app/activation" target="_blank" rel="nofollow noopener noreferrer" class="btn-secondary text-xs">Activate Hot Player / Hot IPTV ↗</a>
              <a href="https://iboproapp.com" target="_blank" rel="nofollow noopener noreferrer" class="btn-secondary text-xs">Activate IBO Player Pro ↗</a>
            </div>
          </div>
        </div>
      </div>

      <!-- App selector list -->
      <h2 id="apps" class="mt-16 font-display text-2xl md:text-3xl font-bold text-text-primary scroll-mt-24">
        Choose an app
      </h2>
      <p class="mt-3 text-text-muted">
        Tap any app to jump to its full step-by-step Windows / Mac IPTV setup.
      </p>
      <ul class="mt-6 space-y-3">
        {apps.map((app) => (
          <li>
            <a
              href={`#${app.slug}`}
              class="card group flex items-center gap-4 p-4 transition hover:border-brand/50"
            >
              <img
                src={app.logo}
                alt={`${app.name} logo`}
                width="48"
                height="48"
                loading="lazy"
                decoding="async"
                class="h-12 w-12 shrink-0 rounded-xl border border-border-subtle bg-elevated"
                onerror="this.src='/og-image.svg'"
              />
              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="text-base font-semibold text-text-primary group-hover:text-brand-light">{app.name}</span>
                  {app.tag === 'free' ? (
                    <span class="rounded-full border border-emerald-400/40 bg-emerald-400/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-emerald-300">Free</span>
                  ) : (
                    <span class="rounded-full border border-amber-400/40 bg-amber-400/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-amber-300">Paid app</span>
                  )}
                  {app.price && (
                    <span class="rounded-full border border-border-subtle bg-elevated/60 px-2 py-0.5 text-[10px] text-text-muted">
                      {app.price}
                    </span>
                  )}
                </div>
                <p class="mt-1 text-xs text-text-muted line-clamp-1">{app.supported}</p>
              </div>
              <span class="text-brand-light shrink-0"><Icon name="chevron-right" size={18} /></span>
            </a>
          </li>
        ))}
      </ul>

      <!-- Per-app deep cards -->
      <div class="mt-14 space-y-14">
        {apps.map((app, idx) => (
          <article id={app.slug} class="card p-6 md:p-8 scroll-mt-24">
            <div class="flex items-start gap-4">
              <img
                src={app.logo}
                alt={`${app.name} logo`}
                width="72"
                height="72"
                loading="lazy"
                decoding="async"
                class="h-16 w-16 md:h-[72px] md:w-[72px] shrink-0 rounded-2xl border border-border-subtle bg-elevated"
                onerror="this.src='/og-image.svg'"
              />
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <p class="text-[11px] font-semibold uppercase tracking-widest text-brand-light">
                    App {idx + 1} of {apps.length}
                  </p>
                  {app.tag === 'free' ? (
                    <span class="rounded-full border border-emerald-400/40 bg-emerald-400/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-emerald-300">Free</span>
                  ) : (
                    <span class="rounded-full border border-amber-400/40 bg-amber-400/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-amber-300">Paid app</span>
                  )}
                </div>
                <h2 class="mt-1 font-display text-2xl md:text-[28px] font-bold text-text-primary">
                  {app.name}
                </h2>
                {app.price && (
                  <p class="mt-1 text-sm text-text-muted">{app.price}</p>
                )}
              </div>
            </div>

            <p class="mt-6 text-text-muted leading-relaxed">{app.copy}</p>

            <div class="mt-6 grid gap-4 sm:grid-cols-2">
              <div class="rounded-xl border border-border-subtle bg-elevated/50 p-4">
                <p class="text-[11px] font-semibold uppercase tracking-widest text-text-muted">Log in via</p>
                <p class="mt-1 text-sm text-text-primary">{app.login}</p>
              </div>
              <div class="rounded-xl border border-border-subtle bg-elevated/50 p-4">
                <p class="text-[11px] font-semibold uppercase tracking-widest text-text-muted">Supported systems</p>
                <p class="mt-1 text-sm text-text-primary">{app.supported}</p>
              </div>
            </div>

            <h3 class="mt-8 font-display text-lg md:text-xl font-semibold text-text-primary">Step-by-step</h3>
            <ol class="mt-4 space-y-4">
              {app.steps.map((s, i) => (
                <li class="flex gap-4">
                  <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-grad-brand text-xs font-bold text-white shadow-glow">
                    {i + 1}
                  </span>
                  <div class="min-w-0">
                    <p class="text-sm md:text-base font-semibold text-text-primary">{s.title}</p>
                    <p class="mt-1 text-sm text-text-muted leading-relaxed">{s.body}</p>
                  </div>
                </li>
              ))}
            </ol>

            {app.tips && app.tips.length > 0 && (
              <div class="mt-6 rounded-xl border border-brand/25 bg-brand/5 p-4">
                <p class="text-[11px] font-semibold uppercase tracking-widest text-brand-light">Tip</p>
                <ul class="mt-2 space-y-1.5 text-sm text-text-muted">
                  {app.tips.map((t) => (
                    <li class="flex gap-2">
                      <span class="mt-1 inline-flex h-4 w-4 shrink-0 items-center justify-center text-brand-light">
                        <Icon name="check" size={14} />
                      </span>
                      <span set:html={t}></span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <div class="mt-6 flex flex-wrap gap-3">
              <a
                href={waLink(`Hi, I'd like to set up ${app.name} on my laptop with your £${site.price} IPTV trial.`)}
                class="btn-primary"
                target="_blank"
                rel="nofollow noopener noreferrer"
              >
                Activate my {app.name}
              </a>
              {app.activateUrl && (
                <a href={app.activateUrl} target="_blank" rel="nofollow noopener noreferrer" class="btn-secondary">
                  Official site ↗
                </a>
              )}
            </div>
          </article>
        ))}
      </div>

      <!-- Comparison -->
      <h2 id="comparison" class="mt-16 font-display text-2xl md:text-3xl font-bold text-text-primary scroll-mt-24">
        Windows &amp; Mac IPTV apps — side-by-side
      </h2>
      <p class="mt-3 text-text-muted">All five desktop apps at a glance.</p>
      <div class="mt-6 overflow-x-auto rounded-2xl border border-border-subtle">
        <table class="w-full min-w-[720px] text-left text-sm">
          <thead class="bg-elevated/70 text-text-primary">
            <tr>
              <th class="p-3 font-semibold">App</th>
              <th class="p-3 font-semibold">Type</th>
              <th class="p-3 font-semibold">Free trial</th>
              <th class="p-3 font-semibold">Login</th>
              <th class="p-3 font-semibold">Price</th>
            </tr>
          </thead>
          <tbody class="text-text-muted">
            {apps.map((app) => (
              <tr class="border-t border-border-subtle/60">
                <td class="p-3 text-text-primary font-medium">{app.name}</td>
                <td class="p-3">{app.tag === 'free' ? 'Free' : 'Paid'}</td>
                <td class="p-3">{app.tag === 'free' ? '—' : (app.price?.match(/\d+-day free trial|7-day free trial|30-day free trial/)?.[0] ?? '7 days')}</td>
                <td class="p-3">{app.login.split('(')[0].trim()}</td>
                <td class="p-3">{app.tag === 'free' ? 'Free' : (app.price?.split('·')[0]?.trim() ?? '—')}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Buyer's guide -->
      <article class="legal-prose mt-16">
        <h2>Which Windows / Mac IPTV app should I actually use?</h2>
        <p>
          If you want the shortest possible answer: install <strong>IPTV Smarters Pro (Desktop)</strong>
          first because it's free and the Xtream Codes login is the exact same one that works on your
          Fire Stick and phone. If the interface feels basic, install <strong>Hot Player</strong> next
          — the 30-day trial covers your whole first month and, if you like it, €14.99 lifetime is
          exceptional value. Kodi is for tinkerers who want to record; VLC is the "no new app" fallback.
        </p>

        <h3>Windows 10 &amp; Windows 11 users</h3>
        <p>
          Every app in this guide runs natively on Windows 10 and 11. Our recommended pairing is
          <strong>IPTV Smarters Pro + IBO Player Pro</strong> — one free with a lightning-fast Xtream
          Codes login, one paid with a proper Netflix-style UI you can drive from the sofa. Both
          accept the same <strong>iptv subscriptions</strong> credentials from us.
        </p>

        <h3>Intel Mac users</h3>
        <p>
          Intel MacBooks and iMacs handle IPTV Smarters Pro, VLC and Kodi flawlessly. Hot Player runs
          via Rosetta 2 and is smooth at 1080p. IBO Player Pro doesn't ship a macOS build yet — Mac
          users should stick to Smarters as the primary player and VLC as backup.
        </p>

        <h3>Apple Silicon (M1 / M2 / M3 / M4) Mac users</h3>
        <p>
          Native ARM builds of <strong>IPTV Smarters Pro</strong>, VLC and Kodi make Apple Silicon
          Macs the smoothest IPTV laptop money can buy — 4K HEVC playback with the fan barely
          spinning up. Just make sure you download the "Apple Silicon" build of each app, not the
          Intel one.
        </p>

        <h2>Try our IPTV UK trial on any of these apps</h2>
        <p>
          Every app on this page works with our <a href="/#pricing">30-day £{site.price} IPTV trial</a> —
          same Xtream Codes credentials or M3U playlist, same UK support on WhatsApp. If you install
          one of the paid apps, your free trial from the app developer runs <em>in parallel</em> with
          our <strong>iptv subscription</strong> trial, so you can properly test both before spending
          a penny more. One set of credentials covers your Windows PC, MacBook, Fire Stick, Smart TV
          and phone — a single <strong>iptv service</strong> for every screen in the house.
        </p>

        <h2>Frequently asked questions</h2>
      </article>

      <!-- FAQ -->
      <div class="mt-8 space-y-3">
        {faqs.map((f) => (
          <details class="group rounded-2xl border border-border-subtle bg-elevated/60 p-5 md:p-6 open:border-brand/40">
            <summary class="flex cursor-pointer list-none items-start justify-between gap-4">
              <h3 class="text-base md:text-lg font-semibold text-text-primary">{f.q}</h3>
              <span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-border-subtle text-brand-light transition group-open:rotate-180">
                <Icon name="chevron-down" size={14} />
              </span>
            </summary>
            <p class="mt-3 text-text-muted leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>

      <!-- Help card -->
      <aside class="mt-14 card p-6 md:p-8">
        <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-text-muted">Stuck?</p>
        <h2 class="mt-2 font-display text-2xl font-semibold text-text-primary">We'll set it up for you</h2>
        <p class="mt-3 text-text-muted">
          Every {site.name} subscription includes free hands-on Windows / Mac setup support. Message
          us on WhatsApp with your operating system and we'll walk you through it, or push your
          playlist across remotely.
        </p>
        <div class="mt-6">
          <a href={waLink(`Hi, I need help setting up IPTV on my Windows PC / Mac.`)} class="btn-primary" target="_blank" rel="nofollow noopener noreferrer">
            <Icon name="whatsapp" size={16} class="mr-2" />
            Chat with UK support
          </a>
        </div>
      </aside>

      <!-- Related guides -->
      <aside class="mt-14">
        <h2 class="font-display text-xl md:text-2xl font-semibold text-text-primary">Other installation guides</h2>
        <ul class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3">
          {relatedGuides.map((g) => (
            <li>
              <a
                href={`/installation-guides/${g.slug}/`}
                class="card group flex items-center justify-between gap-3 p-4 transition hover:border-brand/50"
              >
                <span class="text-sm md:text-base font-medium text-text-primary group-hover:text-brand-light">{g.label}</span>
                <span class="text-brand-light"><Icon name="arrow" size={16} /></span>
              </a>
            </li>
          ))}
        </ul>
      </aside>
    </section>

    <FinalCta />
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</BaseLayout>
